---
import education from "../data/education.json";
import certifications from "../data/certifications.json";

const eduMeta = [education.school, education.years, education.note]
  .filter(Boolean)
  .join(" · ");
---

<section id="education">
  <h2><span class="idx">04</span>Education &amp; Certifications</h2>
  <div class="edu-main">
    <h3>{education.degree}</h3>
    <p class="org">{eduMeta}</p>
  </div>
  <div class="certs">
    {
      certifications.map((cert) => (
        <div class="cert">
          <p class="name">{cert.name}</p>
          <p class="meta">
            {[cert.issuer, cert.year, cert.note].filter(Boolean).join(" · ")}
          </p>
        </div>
      ))
    }
  </div>
</section>

<style>
  section {
    padding: 3.5rem 0;
    border-top: 1px solid var(--line);
  }
  h2 {
    font-size: 1.6rem;
    letter-spacing: -0.02em;
    margin-bottom: 2rem;
  }
  h2 .idx {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--accent);
    vertical-align: super;
    margin-right: 0.5rem;
  }
  .edu-main {
    max-width: 38rem;
    margin-bottom: 2rem;
  }
  .edu-main h3 {
    font-size: 1.12rem;
  }
  .edu-main .org {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }
  .certs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 0.75rem;
  }
  .cert {
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 0.9rem 1rem;
  }
  .cert .name {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.15rem;
  }
  .cert .meta {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ink-soft);
  }
</style>
