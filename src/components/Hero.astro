---
interface Props {
  profile: {
    name: string;
    role: string;
    location: string;
    headline: string;
    tagline: string;
    email: string;
    linkedin: string;
    github: string;
  };
}

const { profile } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const photo = `${base}/photo.jpg`;
---

<header class="hero">
  <div class="hero-row">
    <div class="hero-text">
      <p class="kicker">{profile.role} · {profile.location}</p>
      <h1>{profile.headline}</h1>
      <p class="tagline">{profile.tagline}</p>
      <div class="hero-links">
        <a href={profile.linkedin}>linkedin <span class="ext" aria-hidden="true">↗</span></a>
        <a href={profile.github}>github <span class="ext" aria-hidden="true">↗</span></a>
        <a href={`mailto:${profile.email}`}>email <span class="ext" aria-hidden="true">↗</span></a>
      </div>
    </div>
    <img
      class="portrait"
      src={photo}
      width="170"
      height="170"
      loading="eager"
      alt={`Portrait of ${profile.name}`}
    />
  </div>
</header>

<style>
  header.hero {
    padding: 5.5rem 0 4.5rem;
  }
  .hero-row {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-text {
    flex: 1 1 22rem;
  }
  .kicker {
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 1rem;
  }
  h1 {
    font-size: clamp(2.6rem, 7vw, 3.8rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    text-wrap: balance;
    margin-bottom: 1.25rem;
  }
  .tagline {
    font-size: 1.12rem;
    color: var(--ink-soft);
    max-width: 34rem;
    text-wrap: pretty;
    margin-bottom: 1.75rem;
  }
  .hero-links {
    display: flex;
    gap: 1.5rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    flex-wrap: wrap;
  }
  .portrait {
    width: 170px;
    height: 170px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid var(--line);
    box-shadow: 0 0 0 6px var(--paper), 0 0 0 7px var(--line);
  }
</style>
