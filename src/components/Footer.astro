---
interface Props {
  profile: {
    name: string;
    email: string;
    linkedin: string;
    github: string;
    location: string;
    repo: string;
  };
  ui: { cta: string; builtWith: string; source: string };
}

const { profile, ui } = Astro.props;

const year = new Date().getFullYear();
---

<footer>
  <p class="cta">{ui.cta}</p>
  <div class="links">
    <a class="footer-email" href={`mailto:${profile.email}`}>{profile.email}</a>
    <a href={profile.linkedin}>linkedin <span class="ext" aria-hidden="true">↗</span></a>
    <a href={profile.github}>github <span class="ext" aria-hidden="true">↗</span></a>
  </div>
  <p class="fine">
    © {year} {profile.name} · {ui.builtWith}<span class="source-wrap"> ·
    <a class="source" href={profile.repo}>{ui.source} <span class="ext" aria-hidden="true">↗</span></a></span> · {profile.location}
  </p>
</footer>

<style>
  footer {
    border-top: 1px solid var(--line);
    padding: 3rem 0 4rem;
  }
  footer .cta {
    font-family: var(--display);
    font-weight: 600;
    font-size: 1.4rem;
    margin-bottom: 1rem;
  }
  footer .links {
    display: flex;
    gap: 1.5rem;
    font-family: var(--mono);
    font-size: 0.82rem;
    flex-wrap: wrap;
  }
  footer .fine {
    margin-top: 2.5rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--ink-soft);
  }
  footer .fine .source {
    color: var(--ink-soft);
    transition: color 0.2s ease;
  }
  footer .fine .source:hover,
  footer .fine .source:focus-visible {
    color: var(--accent);
  }
</style>
